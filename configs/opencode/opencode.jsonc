{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "theme": {
    "dark": {
      "background": "#1f2335",
      "foreground": "#a9b1d6",
      "cursor": "#bfbfbf",
      "selection": "#33425c"
    },
    "light": {
      "background": "#ffffff",
      "foreground": "#333333",
      "cursor": "#333333",
      "selection": "#b3d9ff"
    },
    "sync_with_shell": true,
    "state_file": "~/.local/state/theme"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  }
}
