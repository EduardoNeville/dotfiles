{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "theme": {
    "dark": {
      "background": "#011627",
      "foreground": "#d6deeb",
      "cursor": "#80a4c2",
      "selection": "#1d3b53"
    },
    "light": {
      "background": "#fbfbfb",
      "foreground": "#403f53",
      "cursor": "#90a7b2",
      "selection": "#e0e0e0"
    },
    "sync_with_shell": true,
    "state_file": "~/.local/state/theme"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  }
}
